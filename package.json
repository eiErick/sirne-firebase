{
  "name": "sirne",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:app": "bash ./build.sh",
    "sirne:ghpages": "npx ng build --configuration production --base-href 'https://eierick.github.io/sirne-firebase/' --project=sirne && npx angular-cli-ghpages --dir=dist/sirne/browser",
    "maraskin:ghpages": "npx ng build --configuration production --base-href 'https://eierick.github.io/sirne-firebase/' --project=maraskin && npx angular-cli-ghpages --dir=dist/maraskin/browser",
    "sirne": "ng s --port 4200 --project=sirne",
    "maraskin": "ng s --port 4100 --project=maraskin",
    "sibella": "ng build --watch --project=sibella",
    "cerebellum": "ng build --watch --project=cerebellum"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.2",
    "@angular/common": "^20.3.10",
    "@angular/compiler": "^20.3.10",
    "@angular/core": "^20.3.10",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^20.3.10",
    "@angular/material": "^20.2.2",
    "@angular/platform-browser": "^20.3.10",
    "@angular/platform-browser-dynamic": "^20.3.10",
    "@angular/router": "^20.3.10",
    "@angular/service-worker": "^20.3.10",
    "@capacitor/android": "^7.4.3",
    "@capacitor/app": "^7.1.0",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/status-bar": "^7.0.3",
    "@capawesome/capacitor-android-edge-to-edge-support": "^7.2.3",
    "ngx-image-cropper": "^9.1.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.9",
    "@angular/cli": "^20.3.9",
    "@angular/compiler-cli": "^20.3.10",
    "@capacitor/assets": "^3.0.5",
    "@types/jasmine": "~5.1.0",
    "angular-cli-ghpages": "^2.0.3",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.2.0",
    "typescript": "~5.9.2"
  }
}
